{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "exactOptionalPropertyTypes": false,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedSideEffectImports": false,
    "paths": {
      "app/*": ["*"],
      "src/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src-electron/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
