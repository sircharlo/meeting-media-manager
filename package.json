    "heic-convert": "^2.1.0",
    "image-size": "^2.0.2",
    "is-online": "^12.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "mime": "^4.1.0",
    "mousetrap": "^1.6.5",
    "ms": "^2.1.3",
    "music-metadata": "^11.12.3",
    "obs-websocket-js": "^5.0.8",
    "p-queue": "^9.1.0",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pretty-bytes": "^7.1.0",
    "process-nextick-args": "^2.0.1",
    "quasar": "^2.19.2",
