    "fantasticon": "patch:fantasticon@npm%3A4.1.0#~/.yarn/patches/fantasticon-npm-4.1.0-3af043d076.patch",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lodash-es": "^4.18.1",
    "msw": "^2.14.6",
    "oxc-minify": "^0.137.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "6.0.3",
    "vite": "^8.1.1",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": ">=3.3.5 || 3.3.3"
  },
  "resolutions": {
    "vite": "8.1.1"
  },
  "browserslist": [
    "Electron >= 37"
  ],
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,ts,cjs,mjs,mts,vue}": "eslint --fix"
  },
  "engines": {
    "node": "^24.14.0",
    "yarn": "^4.13.0"
  },
  "os": [
